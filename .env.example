# =====================================================
#                    ARAMBH .env
# Copy this to `.env` and tweak for your local setup.
# =====================================================

# --- General ---
ENV=development
PROJECT_NAME=arambh
LOG_LEVEL=INFO

# --- Backend (FastAPI gateway) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- AI Services ---
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8100
AI_SERVICE_URL=http://ai-services:8100

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# --- Default admin (seeded on first boot) ---
ADMIN_EMAIL=admin@arambh.local
ADMIN_PASSWORD=ChangeMe!2025
ADMIN_NAME=Arambh Admin

# --- MongoDB (Atlas) ---
# Get this from Atlas: Cluster -> Connect -> Drivers -> Python -> copy the SRV URI.
# URL-encode special characters in the password (@ -> %40, : -> %3A, etc.).
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=arambh
MONGO_DB=arambh

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=arambh_chunks

# --- Ollama ---
# --- Ollama (running on the host machine, not in Docker) ---
# 'host.docker.internal' resolves to the host from inside containers (mac/win out of the box,
# Linux via the extra_hosts mapping in docker-compose.yml).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.2

# --- Embeddings & Reranker (HuggingFace, local) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Translation (handled by the same Ollama llama3 model — no separate model) ---
SUPPORTED_LANGS=en,hi,mr,ur,ta,te,kn,ml,bn,gu,pa,or,as

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_K=6
HYBRID_ALPHA=0.5
MIN_CONFIDENCE=0.35

# --- Live web search (Perplexity-style) ---
LIVE_SEARCH_ENABLED_DEFAULT=true
LIVE_SEARCH_PROVIDER=duckduckgo
LIVE_SEARCH_TOP_K=5
LIVE_SEARCH_FETCH_TIMEOUT=10.0
LIVE_SEARCH_AUTO_THRESHOLD=0.30
LIVE_SEARCH_FOLLOW_PDFS=true
LIVE_SEARCH_PDF_MAX=10

# --- Crawler ---
CRAWLER_USER_AGENT=ArambhBot/0.1 (+https://arambh.local/bot)
CRAWLER_MAX_DEPTH=10
CRAWLER_MAX_PAGES=500
CRAWLER_RATE_LIMIT_PER_DOMAIN=2.0
CRAWLER_CONCURRENCY=16
CRAWLER_RESPECT_ROBOTS=true

# --- Auto-Refresh Scheduler ---
# Token used by the Celery scheduler to call the internal auto-refresh endpoint
INTERNAL_SCHEDULER_TOKEN=arambh-internal-scheduler
# Default refresh interval for website URLs (hours)
DEFAULT_REFRESH_INTERVAL_HOURS=24

# --- Storage paths (inside containers) ---
DATA_DIR=/data
RAW_HTML_DIR=/data/raw/html
RAW_PDF_DIR=/data/raw/pdf
PROCESSED_DIR=/data/processed
UPLOAD_DIR=/data/uploads

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_AI_BASE_URL=http://localhost:8100
VITE_TTS_BASE_URL=http://localhost:8200
