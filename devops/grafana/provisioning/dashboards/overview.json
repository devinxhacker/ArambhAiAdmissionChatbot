{
  "title": "Arambh Overview",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Backend QPS",
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"backend\"}[1m]))" }],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "AI QPS",
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"ai-services\"}[1m]))" }],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "p95 ask latency (s)",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{handler=~\".*ask.*\"}[5m])))" }],
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 }
    }
  ]
}
